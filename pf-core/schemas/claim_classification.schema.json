{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pf-core.claim_classification.v0",
  "title": "PF-Core Claim Classification",
  "description": "Maps a claim string to T1-T5 category. Version: pf-core.claim_classification.v0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "claim", "category"],
  "properties": {
    "schema_version": { "const": "pf-core.claim_classification.v0" },
    "claim": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "enum": ["T1", "T2", "T3", "T4", "T5"] },
    "evidence_ref": { "type": "string" }
  },
  "examples": [
    {
      "schema_version": "pf-core.claim_classification.v0",
      "claim": "Trace safety decider matches Lean TraceSafe",
      "category": "T1",
      "evidence_ref": "pf-core/lean/PFCore/Soundness.lean"
    }
  ],
  "x-invalid-examples": [
    {
      "description": "invalid category",
      "value": {
        "schema_version": "pf-core.claim_classification.v0",
        "claim": "unclassified",
        "category": "T9"
      }
    }
  ]
}
