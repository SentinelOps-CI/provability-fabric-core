{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pf-core.handoff.v1",
  "title": "PF-Core Handoff (v1)",
  "description": "Delegated capability list with audit metadata; subset of source authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "from_principal",
    "to_principal",
    "delegated_capabilities",
    "reason",
    "evidence_ref"
  ],
  "properties": {
    "schema_version": { "const": "pf-core.handoff.v1" },
    "from_principal": { "$ref": "pf-core.principal.v1" },
    "to_principal": { "$ref": "pf-core.principal.v1" },
    "delegated_capabilities": {
      "type": "array",
      "items": { "$ref": "pf-core.capability.v0" },
      "minItems": 1
    },
    "reason": { "type": "string" },
    "evidence_ref": { "type": "string" }
  },
  "examples": [
    {
      "schema_version": "pf-core.handoff.v1",
      "from_principal": {
        "schema_version": "pf-core.principal.v1",
        "id": "agent-1",
        "tenant_id": "tenant-a",
        "roles": ["agent"],
        "capabilities": []
      },
      "to_principal": {
        "schema_version": "pf-core.principal.v1",
        "id": "agent-2",
        "tenant_id": "tenant-a",
        "roles": ["handoff_delegate"],
        "capabilities": []
      },
      "delegated_capabilities": [
        {
          "schema_version": "pf-core.capability.v0",
          "id": "cap:handoff",
          "effect_kind": "handoff.delegate",
          "resource_pattern": "agent:*"
        }
      ],
      "reason": "delegate handoff authority",
      "evidence_ref": "evidence/handoff.v0"
    }
  ],
  "x-invalid-examples": [
    {
      "description": "missing delegated_capabilities",
      "value": {
        "schema_version": "pf-core.handoff.v1",
        "from_principal": {
          "schema_version": "pf-core.principal.v1",
          "id": "agent-1",
          "tenant_id": "tenant-a",
          "roles": ["agent"],
          "capabilities": []
        },
        "to_principal": {
          "schema_version": "pf-core.principal.v1",
          "id": "agent-2",
          "tenant_id": "tenant-a",
          "roles": ["handoff_delegate"],
          "capabilities": []
        },
        "reason": "missing caps",
        "evidence_ref": "evidence/handoff.v0"
      }
    }
  ]
}
