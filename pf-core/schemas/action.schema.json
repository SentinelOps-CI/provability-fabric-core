{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pf-core.action.v0",
  "title": "PF-Core Action",
  "description": "Principal attempting capability on resource with effect. Version: pf-core.action.v0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "principal", "capability", "resource", "effect"],
  "properties": {
    "schema_version": { "const": "pf-core.action.v0" },
    "principal": { "$ref": "pf-core.principal.v0" },
    "capability": { "$ref": "pf-core.capability.v0" },
    "resource": { "$ref": "pf-core.resource.v0" },
    "effect": { "$ref": "pf-core.effect.v0" }
  },
  "examples": [
    {
      "schema_version": "pf-core.action.v0",
      "principal": {
        "schema_version": "pf-core.principal.v0",
        "id": "agent-1",
        "tenant_id": "tenant-a",
        "roles": ["cap:file-read"]
      },
      "capability": {
        "schema_version": "pf-core.capability.v0",
        "id": "cap:file-read",
        "effect_kind": "file.read",
        "resource_pattern": "/data/*"
      },
      "resource": {
        "schema_version": "pf-core.resource.v0",
        "uri": "/data/report.txt",
        "tenant_id": "tenant-a"
      },
      "effect": {
        "schema_version": "pf-core.effect.v0",
        "kind": "file.read"
      }
    }
  ],
  "x-invalid-examples": [
    {
      "description": "principal lacks capability",
      "value": {
        "schema_version": "pf-core.action.v0",
        "principal": {
          "schema_version": "pf-core.principal.v0",
          "id": "agent-1",
          "tenant_id": "tenant-a",
          "roles": []
        },
        "capability": {
          "schema_version": "pf-core.capability.v0",
          "id": "cap:file-read",
          "effect_kind": "file.read",
          "resource_pattern": "/data/*"
        },
        "resource": {
          "schema_version": "pf-core.resource.v0",
          "uri": "/data/report.txt",
          "tenant_id": "tenant-a"
        },
        "effect": {
          "schema_version": "pf-core.effect.v0",
          "kind": "file.read"
        }
      }
    }
  ]
}
