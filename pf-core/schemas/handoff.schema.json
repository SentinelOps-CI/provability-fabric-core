{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pf-core.handoff.v0",
  "title": "PF-Core Handoff",
  "description": "Bilateral capability transfer between principals. Version: pf-core.handoff.v0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "from_principal", "to_principal", "capability"],
  "properties": {
    "schema_version": { "const": "pf-core.handoff.v0" },
    "from_principal": { "$ref": "pf-core.principal.v0" },
    "to_principal": { "$ref": "pf-core.principal.v0" },
    "capability": { "$ref": "pf-core.capability.v0" }
  },
  "examples": [
    {
      "schema_version": "pf-core.handoff.v0",
      "from_principal": {
        "schema_version": "pf-core.principal.v0",
        "id": "agent-1",
        "tenant_id": "tenant-a",
        "roles": ["cap:handoff"]
      },
      "to_principal": {
        "schema_version": "pf-core.principal.v0",
        "id": "agent-2",
        "tenant_id": "tenant-a",
        "roles": ["cap:handoff"]
      },
      "capability": {
        "schema_version": "pf-core.capability.v0",
        "id": "cap:handoff",
        "effect_kind": "handoff.delegate",
        "resource_pattern": "agent:*"
      }
    }
  ],
  "x-invalid-examples": [
    {
      "description": "cross-tenant handoff",
      "value": {
        "schema_version": "pf-core.handoff.v0",
        "from_principal": {
          "schema_version": "pf-core.principal.v0",
          "id": "agent-1",
          "tenant_id": "tenant-a",
          "roles": ["cap:handoff"]
        },
        "to_principal": {
          "schema_version": "pf-core.principal.v0",
          "id": "agent-2",
          "tenant_id": "tenant-b",
          "roles": ["cap:handoff"]
        },
        "capability": {
          "schema_version": "pf-core.capability.v0",
          "id": "cap:handoff",
          "effect_kind": "handoff.delegate",
          "resource_pattern": "agent:*"
        }
      }
    }
  ]
}
