{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pf-core.action.v1",
  "title": "PF-Core Action (v1)",
  "description": "Multi-effect action with read/write resource lists.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "principal",
    "capability",
    "effects",
    "reads",
    "writes"
  ],
  "properties": {
    "schema_version": { "const": "pf-core.action.v1" },
    "id": { "type": "string" },
    "principal": { "$ref": "pf-core.principal.v1" },
    "capability": { "$ref": "pf-core.capability.v0" },
    "effects": {
      "type": "array",
      "items": { "$ref": "pf-core.effect.v0" },
      "minItems": 1
    },
    "reads": {
      "type": "array",
      "items": { "$ref": "pf-core.resource.v0" }
    },
    "writes": {
      "type": "array",
      "items": { "$ref": "pf-core.resource.v0" }
    }
  },
  "examples": [
    {
      "schema_version": "pf-core.action.v1",
      "id": "act-example",
      "principal": {
        "schema_version": "pf-core.principal.v1",
        "id": "agent-1",
        "tenant_id": "tenant-a",
        "roles": ["agent"],
        "capabilities": ["cap:file-read"]
      },
      "capability": {
        "schema_version": "pf-core.capability.v0",
        "id": "cap:file-read",
        "effect_kind": "file.read",
        "resource_pattern": "/data/*"
      },
      "effects": [
        {
          "schema_version": "pf-core.effect.v0",
          "kind": "file.read"
        }
      ],
      "reads": [
        {
          "schema_version": "pf-core.resource.v0",
          "uri": "/data/report.txt",
          "tenant_id": "tenant-a"
        }
      ],
      "writes": []
    }
  ],
  "x-invalid-examples": [
    {
      "description": "empty effects array",
      "value": {
        "schema_version": "pf-core.action.v1",
        "id": "act-bad",
        "principal": {
          "schema_version": "pf-core.principal.v1",
          "id": "agent-1",
          "tenant_id": "tenant-a",
          "roles": ["agent"],
          "capabilities": ["cap:file-read"]
        },
        "capability": {
          "schema_version": "pf-core.capability.v0",
          "id": "cap:file-read",
          "effect_kind": "file.read",
          "resource_pattern": "/data/*"
        },
        "effects": [],
        "reads": [],
        "writes": []
      }
    }
  ]
}
